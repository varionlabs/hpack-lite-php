{
  "name": "varionlabs/minipack",
  "description": "Minimal HPACK encoder/decoder for HTTP/2 header blocks (static table only).",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Hpack\\": "src/Hpack/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Minihpack\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "keywords": [
    "hpack",
    "http2",
    "compression",
    "header"
  ],
  "homepage": "https://github.com/varionlabs/minihpack-php",
  "support": {
    "source": "https://github.com/varionlabs/minihpack-php"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
